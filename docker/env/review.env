RUBY_ENV=review
DATABASE_URL=postgres://ip_monitoring:ip_monitoring@db:5432/ip_monitoring_review
DB_LOG=false
POSTGRES_DB=ip_monitoring_review
POSTGRES_USER=ip_monitoring
POSTGRES_PASSWORD=ip_monitoring
IP_MONITORING_API_PORT=3000

# Worker defaults
IP_MONITORING_WORKER_CHECK_INTERVAL_SEC=60
IP_MONITORING_WORKER_POLL_INTERVAL_SEC=1
IP_MONITORING_WORKER_BATCH_SIZE=500
IP_MONITORING_WORKER_THREADS=50
IP_MONITORING_WORKER_PING_TIMEOUT_SEC=1
